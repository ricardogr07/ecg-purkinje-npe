#!/usr/bin/env bash
# Strip any AI/Claude attribution so individual commits stay clean.
# Claude usage is disclosed once, in the hackathon writeup, not per commit.
set -euo pipefail
f="$1"
grep -viE '^Co-Authored-By:.*(Claude|noreply@anthropic\.com)' "$f" > "$f.tmp" && mv "$f.tmp" "$f"
grep -viE '(Generated with (\[)?Claude|Claude Code|Generated by Claude|robot_face)' "$f" > "$f.tmp" && mv "$f.tmp" "$f"
# trim only TRAILING blank lines; preserve the subject/body blank-line structure
sed -i -e :a -e '/^[[:space:]]*$/{$d;N;ba}' "$f" 2>/dev/null || true
exit 0
