# Python
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Data & artifacts (large / regenerated, publish checkpoints via releases).
# Anchored to repo root so it ignores the top-level Strocchi download only, not the
# small demo geometry vendored inside packages/purkinje-uv/data. Track only data/README.md
# and data/.gitkeep (the raw meshes are hundreds of MB of CC-BY data that lives on Zenodo).
/data/*
!/data/.gitkeep
!/data/README.md
*.vtk
*.vtu
*.case
*.geo
*.tar.gz
runs/
outputs/
checkpoints/
sbi-logs/
*.pt
*.pkl

# Node / Next.js
ui/node_modules/
ui/.next/
ui/out/

# Infra / secrets, NEVER commit
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
.env
.env.*
credentials.json
*token*.json

# OS / editor
.DS_Store
.vscode/

# Local-only orchestration and strategy
.localagent/
.claude/
.claude_design/

# transient FUSE temp files
.fuse_hidden*

# Vendored simulator libraries (packages/*): keep their bundled demo assets tracked,
# overriding the global data / *.vtk / *.vtu / *.pkl rules above so the crtdemo geometry,
# fibers, electrodes, and ground-truth ECG ship with the repo.
!packages/**/data/
!packages/**/data/**

# Research lane working notes (internal, like .claude and .localagent)
.claude_research/
/contract_b.json

# local dev-server + junk (not canonical; repo lockfile is package-lock.json)
ui/dev-server.log
ui/pnpm-lock.yaml
ui/pnpm-workspace.yaml
*.stackdump
